# ========================================
# OceanVerse — .gitignore
# ========================================

# ---------- 敏感配置 ----------
**/application-local.yml

# ---------- 构建产物 ----------
**/target/

# ---------- IDE ----------
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~

# ---------- 运行时生成 ----------
data/ai/vector-store.json
**/*.log

# ---------- 密钥文件（切勿提交） ----------
*.pem
*.key
*.p12
*.pfx
*.jks

# ---------- 环境文件 ----------
.env
.env.*
!.env.example

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Node / 前端 ----------
**/node_modules/
**/dist/

# ---------- Docker ----------
**/docker-compose.override.yml
