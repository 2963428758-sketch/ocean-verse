*.key
*.p12
*.pfx
*.jks

# ---------- 环境文件 ----------
.env
.env.*
!.env.example

# ---------- OS ----------
.DS_Store
Thumbs.db
desktop.ini

# ---------- Node / 前端 ----------
**/node_modules/
**/dist/

# ---------- Docker ----------
**/docker-compose.override.yml
/docs/
/OceanVerse-backend/smart-ai-service/data/
/data/
/OceanVerse实训报告.md
/《软件工程项目开发校企业实训》-软件1232-1219-李猷.doc
