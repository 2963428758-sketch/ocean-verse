# ---------- 构建产物 ----------
**/target/

# ---------- IDE ----------
.idea/
*.iml
*.iws
*.ipr
.vscode/
*.swp
*.swo
*~

# ---------- 运行时生成 ----------
smart-ai-service/data/ai/vector-store.json
smart-ai-service/data/ai/vector-store.json.meta
smart-ai-service/data/ai/cache-vector-store.json
